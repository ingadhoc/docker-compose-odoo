# docker-compose.override.yml — opt-in mounts de proyectos del ecosistema
# adhoc-way.
#
# Cómo usar:
#   1. Copiá este archivo a `docker-compose.override.yml` (ya está
#      gitignored).
#   2. Descomentá los mounts de los proyectos que querés ver adentro del
#      devcontainer.
#   3. Rebuild del devcontainer (`Dev Containers: Rebuild Container`).
#
# Convención de paths host por defecto (decisión §6 #12 del spec OBA bake,
# ingadhoc/adhoc-way#99):
#
#   ${HOME}/repositorios/devops/    → /home/odoo/custom/devops
#   ${HOME}/repositorios/adhoc-way/ → /home/odoo/custom/adhoc-way
#   ${HOME}/tuqui/                  → /home/odoo/custom/tuqui  (opt-in extra)
#
# Si tu repo vive en otro path, ajustá la línea correspondiente. El target
# adentro del container (`/home/odoo/custom/<proyecto>`) no se cambia —
# poststart.sh detecta el mount buscando `custom/<proyecto>/AGENTS.md`.
#
# Sin compat hacia atrás con paths legacy `custom/<proyecto>-ctx/` (decisión
# §6 #14): si venías del modelo viejo de clones internos, los repos ahora
# viven en el host. JJS + AZ adaptan setups locales post-merge.

services:
  odoo:
    volumes:
      # devops workspace (multi-repo: oci-odoo-by-adhoc, helm-charts,
      # devops-cloud-infra, pylib_odoo_saas, devops-ops-tools, devops-specs).
      # Activar para tareas DevOps puras o cross-team Odoo↔Infra.
      # - ${HOME}/repositorios/devops:/home/odoo/custom/devops

      # adhoc-way meta-repo (specs, decisions, scripts cross-vendor,
      # binario `adhoc-way`, templates AGENTS.md/CLAUDE.md/GEMINI.md).
      # Activar para devs que tocan el meta-flujo (raro para dev OBA puro).
      # - ${HOME}/repositorios/adhoc-way:/home/odoo/custom/adhoc-way

      # tuqui workspace (umbrella con satélites — tuqui-runbot, evals,
      # multica, etc.). Activar para devs OBA que tocan Tuqui ocasionalmente.
      # - ${HOME}/tuqui:/home/odoo/custom/tuqui

      # Recursivo: el propio docker-compose-odoo (el repo que define este
      # devcontainer). Útil para editarlo desde adentro de un container
      # corriendo, sin salir al host. Suele activarse junto con `devops`
      # (donde docker-compose-odoo aparece como uno más de los satélites).
      # - ${HOME}/repositorios/docker-compose-odoo:/home/odoo/custom/devops/docker-compose-odoo
