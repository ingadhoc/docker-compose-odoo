{
  // Variante DevOps del devcontainer base (../devcontainer.json).
  // Agrega kubectl + helm vía devcontainer feature y monta ~/.kube (readonly).
  // Para usar: "Reopen in Container" → elegir "Odoo Adhoc — DevOps".
  // Mantener en sincronía con ../devcontainer.json cuando cambie config base.
  "name": "Odoo Adhoc — DevOps",
  "dockerComposeFile": [
    "../../docker-compose.yml",
    "../../docker-compose.auto-mounts.yml"
  ],
  "service": "odoo",
  "initializeCommand": ".devcontainer/scripts/discover-mounts.sh",
  "workspaceFolder": "/home/odoo/custom",
  "mounts": [
    {
      "source": "${localWorkspaceFolder}/.devcontainer/scripts",
      "target": "/scripts",
      "type": "bind"
    },
    {
      "source": "${localWorkspaceFolder}/.devcontainer/.vscode",
      "target": "/home/odoo/custom/.vscode",
      "type": "bind"
    },
    // ~/.kube del host montado readonly; kubectl usa /home/odoo/.kube/config por defecto.
    // Si el uid del host difiere del uid odoo (1000), ajustar permisos en el host.
    {
      "source": "${localEnv:HOME}/.kube",
      "target": "/home/odoo/.kube",
      "type": "bind",
      "readonly": true
    },
    // ~/.config/gcloud del host montado readonly; expone auth ADC y config activa
    // sin necesidad de re-autenticar dentro del container.
    {
      "source": "${localEnv:HOME}/.config/gcloud",
      "target": "/home/odoo/.config/gcloud",
      "type": "bind",
      "readonly": true
    }
  ],

  // Herramientas instaladas como features (cacheadas en la imagen, no en postCreate).
  "features": {
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helmVersion": "latest",
      "minikubeVersion": "none"
    }
  },

  "shutdownAction": "stopCompose",
  "postCreateCommand": "/scripts/poststart.sh > /tmp/postCreateCommand.log 2>&1",
  "postStartCommand": "/scripts/share-claude-sessions.sh > /tmp/postStartCommand.log 2>&1",
  "onCreateCommand": "/scripts/oncreate.sh > /tmp/onCreateCommand.log 2>&1",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/scripts/user",
    "AD_DEV_MODE": "NORMAL",
    "AD_DEV_USER_TYPE": "DEVOPS",
    // KUBECONFIG explícito por si el archivo no está en el path default dentro del container.
    "KUBECONFIG": "/home/odoo/.kube/config"
  },

  "customizations": {
    "vscode": {
      "remoteUser": "odoo",
      "settings": {
        "files.insertFinalNewline": true,
        "terminal.integrated.cwd": "/home/odoo/custom",
        "remote.autoForwardPorts": false,
        "files.watcherExclude": {
          "/home/odoo/src/**": true,
          "/home/odoo/custom/src/**": true,
          "/home/odoo/custom/adhoc/**": true
        },
        "files.associations": {
          "*.json": "jsonc"
        },
        "files.exclude": {
          ".devcontainer": true,
          ".github": true,
          "*.Dockerfile.dockerignore": true,
          ".agents": true,
          ".claude": true,
          ".codex": true,
          ".gemini": true,
          ".adhoc": true
        },
        "search.exclude": {
          ".devcontainer": true,
          "dockerfiles": true,
          ".github": true,
          "src": false,
          "adhoc": true
        },
        "python.defaultInterpreterPath": "/home/odoo/venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "python.linting.enabled": true,
        "python.linting.ruffEnabled": true,
        "ruff.exclude": ["/home/odoo/src/**"],
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll": "explicit",
          "source.organizeImports": "explicit"
        },
        "python.languageServer": "Pylance",
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.useLibraryCodeForTypes": false,
        "python.analysis.diagnosticSeverityOverrides": {
          "reportAttributeAccessIssue": "none",
          "reportCallIssue": "warning",
          "reportGeneralTypeIssues": "warning",
          "reportArgumentType": "warning"
        },
        "editor.quickSuggestions": { "strings": true },
        "python.analysis.languageServerMode": "light",
        "python.analysis.extraPaths": [
          "/home/odoo/src/odoo",
          "/home/odoo/src/enterprise",
          "/home/odoo/src/odoo-module-migrator",
          "/home/odoo/src/odoo-upgrade",
          "/home/odoo/src/odooly",
          "/home/odoo/src/openupgradelib",
          "/home/odoo/src/upgrade-util"
        ],
        "python.analysis.exclude": ["/home/odoo/custom/adhoc/**"],
        "python.analysis.autoSearchPaths": true,
        "python.analysis.diagnosticMode": "openFilesOnly",
        "python.analysis.indexing": true,
        "python.analysis.userFileIndexingLimit": -1,
        "Odoo.serverConfigPath": "/home/odoo/custom/repositories/odools.toml",
        "cSpell.diagnosticLevel": "Hint",
        "cSpell.diagnosticLevelFlaggedWords": "Hint",
        "trailing-spaces.highlightCurrentLine": true,
        "trailing-spaces.syntaxIgnore": ["markdown"],
        "debug.toolBarLocation": "commandCenter",
        "debug.openDebug": "neverOpen",
        "debug.openExplorerOnEnd": true,
        "debug.allowBreakpointsEverywhere": true,
        "debug.hideLauncherWhileDebugging": true,
        "debug.internalConsoleOptions": "neverOpen",
        "debugpy.showPythonInlineValues": true,
        "autoDocstring.guessTypes": true,
        "autoDocstring.docstringFormat": "google",
        "autoDocstring.generateDocstringOnEnter": true,
        "extensions.ignoreRecommendations": true,
        // Kubernetes tools
        "vs-kubernetes.kubeconfig": "/home/odoo/.kube/config"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "ms-vsliveshare.vsliveshare",
        "shardulm94.trailing-spaces",
        "streetsidesoftware.code-spell-checker",
        "njpwerner.autodocstring",
        "Odoo.odoo",
        "zaaack.markdown-editor",
        "anthropic.claude-code",
        // Devops extras
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker"
      ],
      "remote.defaultExtensionsIfInstalledLocally": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github"
      ]
    }
  }
}
